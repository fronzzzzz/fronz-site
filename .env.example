# Customer.io Tracking API — powers the GTM Clarity Starter lead form (app/api/lead).
# Find these under Customer.io → Settings → API Credentials → Tracking API Keys.
CUSTOMERIO_SITE_ID=
CUSTOMERIO_TRACK_API_KEY=
# Set to "eu" if your Customer.io workspace is in the EU region; otherwise "us".
CUSTOMERIO_REGION=us
