# Customer.io Tracking API — powers the lead form (app/api/lead) and the
# /starter "send your map" capture (app/api/starter). Use the FRONZ workspace's
# keys: Customer.io → Settings → API Credentials → Tracking API Keys.
CUSTOMERIO_SITE_ID=
CUSTOMERIO_TRACK_API_KEY=
# Set to "eu" if your Customer.io workspace is in the EU region; otherwise "us".
CUSTOMERIO_REGION=us

# Duplicatable "work in it" templates shown on /starter. These have live
# defaults in lib/content.ts (public share links, not secrets); only set these
# to override per-environment.
NEXT_PUBLIC_STARTER_NOTION_TEMPLATE_URL=
NEXT_PUBLIC_STARTER_GDOC_TEMPLATE_URL=

# Phase 2 — mirror submitted Starter maps into Fronz Notion as child pages.
# NOTION_TOKEN: the FRONZ Notion internal integration token (starts "ntn_").
# NOTION_STARTER_PARENT_ID: the "GTM Clarity Starter — Submissions" page id.
#   Already created and shared with the integration:
#   https://app.notion.com/p/GTM-Clarity-Starter-Submissions-3898234f4e908171bfaaf5c46ffc3e04
NOTION_TOKEN=
NOTION_STARTER_PARENT_ID=3898234f-4e90-8171-bfaa-f5c46ffc3e04

# Calendly inline embed on /book (includes brand color query params).
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/fronzz/initial-consult?background_color=f3efe4&text_color=1c1e17&primary_color=1c1e17
